NODE_ENV=production
DEPLOYMENT_ENV=staging
DATABASE_URL=postgresql://bazaarsetu:replace-neon-password@replace-neon-host/bazaarsetu_staging?sslmode=require
REDIS_URL=rediss://default:replace-upstash-password@replace-upstash-host:6379
API_PORT=5010
API_BASE_URL=https://api-staging.bazaarsetu.example
CORS_ORIGINS=https://admin-staging.bazaarsetu.example,https://customer-staging.bazaarsetu.example,https://seller-staging.bazaarsetu.example
REQUEST_BODY_LIMIT=2mb
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=60
DEMO_AUTH_ENABLED=false
ACCESS_TOKEN_TTL_SECONDS=900
REFRESH_TOKEN_TTL_DAYS=30
OTP_TTL_SECONDS=300
OTP_MAX_ATTEMPTS=5
OTP_DELIVERY_MODE=mock
NEXT_PUBLIC_API_BASE_URL=https://api-staging.bazaarsetu.example
EXPO_PUBLIC_API_BASE_URL=https://api-staging.bazaarsetu.example

JWT_SECRET=replace-with-32-plus-random-characters
OTP_PROVIDER_URL=
OTP_PROVIDER_API_KEY=
OTP_PROVIDER_SENDER=Bazaar Setu
OTP_CODE_PEPPER=replace-with-different-32-plus-random-characters
ADMIN_BOOTSTRAP_TOKEN=replace-with-one-time-32-plus-random-characters
GOOGLE_MAPS_API_KEY=replace-with-staging-google-maps-key
RAZORPAY_KEY_ID=replace-with-staging-razorpay-key-id
RAZORPAY_KEY_SECRET=replace-with-staging-razorpay-secret
S3_BUCKET=replace-with-staging-upload-bucket
S3_REGION=ap-south-1
S3_ACCESS_KEY_ID=replace-with-staging-s3-key
S3_SECRET_ACCESS_KEY=replace-with-staging-s3-secret
FCM_SERVER_KEY=replace-with-staging-fcm-key
